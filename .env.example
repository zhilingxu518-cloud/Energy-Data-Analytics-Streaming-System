# OpenElectricity API key — obtain from https://openelectricity.org.au
OPENELECTRICITY_API_KEY=your_api_key_here

# MQTT broker configuration (defaults to public test broker)
MQTT_BROKER=test.mosquitto.org
MQTT_PORT=1883
MQTT_TOPIC=NEM/PowerEmissions
MQTT_USER=
MQTT_PASS=

# Set to "0" to disable MQTT and run with CSV data only
USE_MQTT=1

# Path to the merged data CSV
TOTAL_CSV=total.csv

# Streamlit refresh interval (seconds)
REFRESH_SEC=2.0

# Default dot radius on map (meters)
DEFAULT_RADIUS_M=9000
